{
  "name": "@tangent/usage-providers",
  "version": "0.1.0",
  "description": "Usage provider adapters and native transcript loaders.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./providers/*": {
      "types": "./src/providers/*.ts",
      "import": "./dist/providers/*.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test test/*.test.mjs"
  },
  "dependencies": {
    "@tangent/repo": "^0.1.0",
    "@tangent/usage-core": "^0.1.0",
    "@tangent/usage-schema": "^0.1.0"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  }
}
