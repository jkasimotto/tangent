{
  "name": "@tangent/usage-core",
  "version": "0.1.0",
  "description": "Dependency-light in-memory Usage query and projection package.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./src/core/index.ts",
      "import": "./dist/core/index.js"
    },
    "./core/*": {
      "types": "./src/core/*.ts",
      "import": "./dist/core/*.js"
    },
    "./query": {
      "types": "./src/query/index.ts",
      "import": "./dist/query/index.js"
    },
    "./query/*": {
      "types": "./src/query/*.ts",
      "import": "./dist/query/*.js"
    },
    "./schema": {
      "types": "./src/schema/index.ts",
      "import": "./dist/schema/index.js"
    },
    "./schema/*": {
      "types": "./src/schema/*.ts",
      "import": "./dist/schema/*.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test test/*.test.mjs"
  },
  "dependencies": {
    "@tangent/core": "^0.1.0",
    "@tangent/repo": "^0.1.0",
    "@tangent/usage-schema": "^0.1.0"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  }
}
