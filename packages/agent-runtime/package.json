{
  "name": "@tangent/agent-runtime",
  "version": "0.1.0",
  "description": "Shared process and agent runner primitives for Tangent apps.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./process": {
      "types": "./dist/process.d.ts",
      "import": "./dist/process.js"
    },
    "./notify": {
      "types": "./dist/notify.d.ts",
      "import": "./dist/notify.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test test/*.test.mjs"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  }
}
