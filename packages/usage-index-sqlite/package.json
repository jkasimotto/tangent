{
  "name": "@tangent/usage-index-sqlite",
  "version": "0.1.0",
  "description": "SQLite projection/index package for Usage telemetry.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./sdk/*": {
      "types": "./src/sdk/*.ts",
      "import": "./dist/sdk/*.js"
    },
    "./sqlite": {
      "types": "./src/sqlite/index.ts",
      "import": "./dist/sqlite/index.js"
    },
    "./sqlite/*": {
      "types": "./src/sqlite/*.ts",
      "import": "./dist/sqlite/*.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test test/*.test.mjs"
  },
  "dependencies": {
    "@tangent/usage-core": "^0.1.0",
    "@tangent/usage-providers": "^0.1.0",
    "@tangent/repo": "^0.1.0",
    "@tangent/usage-schema": "^0.1.0"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.10.0"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  }
}
