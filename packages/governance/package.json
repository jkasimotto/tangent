{
  "name": "@tangent/governance",
  "version": "0.1.0",
  "description": "Architecture, docs, dependency, and agent-legibility lints for Tangent.",
  "type": "module",
  "bin": {
    "tangent-governance": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "import": "./dist/cli/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/cli/index.js",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test test/*.test.mjs"
  },
  "dependencies": {
    "@tangent/core": "^0.1.0"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  }
}
