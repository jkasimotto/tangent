{
  "name": "@tangent/usage-ui",
  "version": "0.1.0",
  "description": "Svelte UI for Tangent Usage sessions and telemetry.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./assets": {
      "types": "./src/assets.ts",
      "import": "./dist/assets.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "vite build && vite build --config vite.embedded.config.ts && tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build -w @tangent/usage-ui-data && npm run build && vitest run --environment jsdom"
  },
  "dependencies": {
    "@tangent/usage-ui-data": "^0.1.0",
    "@tangent/ui-tokens": "^0.1.0",
    "svelte": "^5.56.3"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@testing-library/svelte": "^5.3.1",
    "vite": "^6.3.5"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  }
}
