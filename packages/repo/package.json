{
  "name": "@tangent/repo",
  "version": "0.1.0",
  "description": "Repository discovery, git, worktree, and path helpers for Tangent apps.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./discover": {
      "types": "./dist/discover.d.ts",
      "import": "./dist/discover.js"
    },
    "./git": {
      "types": "./dist/git.d.ts",
      "import": "./dist/git.js"
    },
    "./paths": {
      "types": "./dist/paths.d.ts",
      "import": "./dist/paths.js"
    },
    "./worktree": {
      "types": "./dist/worktree.d.ts",
      "import": "./dist/worktree.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test test/*.test.mjs"
  },
  "dependencies": {
    "@tangent/core": "^0.1.0"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  }
}
